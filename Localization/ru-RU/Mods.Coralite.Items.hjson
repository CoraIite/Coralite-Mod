BloodmarkTopper: {
	ExtraToolTipNone:
		'''
		Даёт [c/ed494e:Кровавый цилиндр]!
		    ▶ Призывает кровавый цилиндр, который цепляется к ближайшему врагу и кусает
		'''
	ExtraToolTipBlood:
		'''
		Даёт [c/ed494e:Кровавый цилиндр]!
		    ▶ Призывает кровавый цилиндр, который цепляется к ближайшему врагу и кусает
		'''
	ExtraToolTipShadow:
		'''
		Даёт [c/f148eb:Теневой цилиндр]!
		    ▶ Призывает теневой цилиндр, который кусает врагов и призывает теневичков
		    ▶ Теневички возвращаются после атаки, давая стаки:
		      Атака +3% за стак (макс. 15%)
		      Макс. HP +5 за стак (макс. 25)
		      Защита +1 за стак (макс. 5)
		    ▶ Потеря одного стака каждые 12 сек
		'''
	ExtraToolTipPrison:
		'''
		Даёт [c/665cc2:Грешный цилиндр]!
		    ▶ Призывает грешный цилиндр, стреляющий железными шипами при ударе кнутом
		    ▶ Каждые 5 атак создаёт клешни, снижающие защиту цели на 8
		'''
	SpecialPreNameBlood: Кровожадный
	SpecialPreNameShadow: Теневой
	SpecialPreNamePrison: Палач
	ArmorSetBlood:
		'''
		+10 защиты, сильное ускорение регенерации
		Даёт [c/ed494e:Кровавый бассейн]!
		    ▶ Укусы кровавого цилиндра накапливают стаки (макс. 5), превращаясь в капли крови
		    ▶ Капли добавляют 2 крови в бассейн (макс. 50) и вампиризм
		    ▶ Зелья лечения расходуют кровь для усиления лечения
		'''
	ArmorSetShadow:
		'''
		+6 защиты, увелич. скорость и ускорение передвижения
		Заменяет [c/ed494e:Кровавый цилиндр] на [c/f148eb:Теневой цилиндр]
		'''
	ArmorSetPrison:
		'''
		+6 защиты, +30% дальность кнута, +15% скорость кнута, +15% призывной урон
		Заменяет [c/ed494e:Кровавый цилиндр] на [c/665cc2:Грешный цилиндр]
		'''
	DisplayName: Цилиндр кровавой метки
	Tooltip:
		'''
		+8% урона, +5% крит. шанса
		ПКМ в инвентаре для переключения косметического вида
		'''
	SetTip: Экипируйте багровую [i:793][i:794], теневую [i:101][i:100][i:957][i:958] или обсидиановую [i:3267][i:3268] броню для бонусов комплекта
}

