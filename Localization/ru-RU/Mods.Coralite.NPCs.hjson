}

ElfRanger: {
	Name1: Эйф
	Name2: Ита
	Name3: Мистейл
	Name4: Дарлумар
	Name5: Кориа
	Name6: Сельда
	DisplayName: Эльфийский защитник

	TownNPCMood: {
		Content: Я очень доволен.
		NoHome: Я ненавижу отсутствие дома.
		FarFromHome: Я слишком далеко от дома.
		LoveSpace: Мне очень нравится такое большое пространство.
		DislikeCrowded: Мне не нравится, когда слишком много людей.
		HateCrowded: Мне не нравится, когда слишком много людей.
		LoveBiome: Я очень люблю {BiomeName}.
		LikeBiome: Мне нравится {BiomeName}.
		DislikeBiome: Мне не нравится {BiomeName}.
		LoveNPC: Мне очень нравится {NPCName}.
		LikeNPC: Мне нравится {NPCName}.
		DislikeNPC: Мне не нравится {NPCName}.
		HateNPC: Я ненавижу {NPCName}.
		LikeNPC_Princess: Мне нравится {NPCName}.
		Princess_LovesNPC: Мне нравится {NPCName}.
	}

	Name7: Филси
	Chat1: Наблюдать за этими малыми существами очень интересно, я часто смотрю на них весь день.
	Chat2: У фей есть любимые стены, только перед этими стенами можно встретить их.
	Chat3: Ты знаешь о магической пыли? Феи очень любят эту волшебную пыль.
	Chat4: Если ты хочешь поймать фей, сделай ловушку из лиан!
	Chat5: Ловить фей и выращивать их довольно распространено, но не переусердствуй!
	Chat6: Ты видел кораллы? Именно она привела меня сюда.
	Chat7: Возможно, когда-нибудь ты встретишь пространственную фею и пройдешь ее испытание.
	DryadChat1: Это древесное существо? Думаю, я давно не видел ее.
	DryadChat2: Древесное существо когда-то сражалось с Ктулху, а я был в другом мире... это было очень давнее время.
	DryadChat3: Древесное существо издает запах леса, мне очень нравится этот аромат.
	// Census.SpawnCondition: Conditions unknown
}

