			'''
	}

	Slime1Knowledge: {
		Name: Фрагмент свитка слизи
		LockTip:
			'''
			Иногда слизни носят с собой саженцы слизистого дерева.
			Получите «Саженец слизистого дерева» и откройте «Фрагмент свитка магии. Часть 1».
			'''
		Description:
			'''
			Содержит информацию о великом императоре.
			Из страны слизи.
			'''
		LifeMaxBonus_1:
			'''
			Увеличение здоровья 1 | Опасность 1
			    ▶ Здоровье Императора слизи увеличено на 50%
			    ▶ Усиления одного типа не складываются
			'''
		LifeMaxBonus_2:
			'''
			Увеличение здоровья 2 | Опасность 2
			    ▶ Здоровье Императора слизи увеличено на 75%
			    ▶ Усиления одного типа не складываются
			'''
		LifeMaxBonus_3:
			'''
			Увеличение здоровья 3 | Опасность 3
			    ▶ Здоровье Императора слизи увеличено на 100%
			    ▶ Усиления одного типа не складываются
			'''
		DefenceBonus_1:
			'''
			Увеличение защиты 1 | Опасность 1
			    ▶ Защита Императора слизи увеличена на 8
			    ▶ Усиления одного типа не складываются
			'''
		DefenceBonus_2:
			'''
			Увеличение защиты 2 | Опасность 2
			    ▶ Защита Императора слизи увеличена на 15
			    ▶ Усиления одного типа не складываются
			'''
		SpeedBonus1_1:
			'''
			Скоростные действия 1 | Опасность 1
			    ▶ Скорость прыжков и падения Императора слизи увеличена
			    ▶ Усиления одного типа складываются
			'''
		SpeedBonus2_1:
			'''
			Скоростные действия 2 | Опасность 1
			    ▶ Скорость в форме короны и скорость упругой деформации Императора слизи увеличены
			    ▶ Усиления одного типа складываются
			'''
		SpeedBonus3_1:
			'''
			Скоростные действия 3 | Опасность 1
			    ▶ Порядок атак Императора слизи изменён, некоторые атаки быстрее
			    ▶ Усиления одного типа складываются
			'''
		WeaponLimit_4:
			'''
			Ограничение оружия | Опасность 4
			    ▶ Можно использовать только оружие редкости не выше ярко-красной с уроном ≤ 45
			    ▶ При включении этой модификации призванные существа нужно призвать заново после входа в бой
			'''
		ArmorLimit_4:
			'''
			Ограничение брони | Опасность 4
			    ▶ Можно носить только броню и аксессуары редкости не выше розовой с защитой каждой части ≤ 9
			'''
		HitLimit_3:
			'''
			Ограничение получаемого урона | Опасность 3
			    ▶ За весь бой можно получить не более 10 попаданий
			'''
		HitLimit_S_5:
			'''
			Ограничение получаемого урона S | Опасность 5
			    ▶ За весь бой можно получить не более 1 попадания
			'''
		FlippyBonus_1:
			'''
			Усиление крыльев 1 | Опасность 1
			    ▶ Крылатый слизень больше не теряет здоровье при создании гелевых шаров,
			      а исчезает после создания 12 гелевых шаров
			    ▶ Здоровье крылатого слизня увеличено на 25%
			    ▶ Усиления одного типа складываются
			'''
		FlippyBonus_S_2:
			'''
			Усиление крыльев 2 | Опасность 2
			    ▶ Крылатый слизень двигается быстрее и создаёт гелевые шары быстрее,
			      направление скорости при падении изменено
			    ▶ Усиления одного типа складываются
			'''
		AvatarBonus_1:
			'''
			Усиление стражей 1 | Опасность 1
			    ▶ Здоровье слуг слизи увеличено на 50%, при разделении передаётся полное здоровье
			    ▶ Усиления одного типа складываются
			'''
		AvatarBonus_S_2:
			'''
			Усиление стражей 2 | Опасность 2
			    ▶ Слуги слизи разделяются быстрее
			    ▶ Слуги слизи могут разделяться на 3, разлетаясь в разные стороны
			    ▶ Усиления одного типа складываются
			'''
		CrownBonus_1:
			'''
			Усиление короны | Опасность 1
			    ▶ В форме короны защита Императора слизи дополнительно увеличена на 20
			    ▶ Усиления одного типа не складываются
			'''
		CrownBonus_S_2:
			'''
			Усиление короны S | Опасность 2
			    ▶ В форме короны Император слизи получает суперброню (весь урон уменьшается до 1)
			      и отражает часть снарядов
			    ▶ Усиления одного типа не складываются
			'''
		ElasticBonus_1:
			'''
			Усиление упругости | Опасность 1
			    ▶ Упругие гелевые шары больше не лопаются от атак
			'''
		GelBallBonus_P1_2:
			'''
			Усиление гелевых шаров. Форма 1 | Опасность 2
			    ▶ Гелевые шары при отскоке не теряют скорость и отклоняются к игроку,
			      количество отскоков увеличено
			    ▶ Усиления одного типа взаимоисключаемы
			'''
		GelBallBonus_P2_2:
			'''
			Усиление гелевых шаров. Форма 2 | Опасность 2
			    ▶ Гелевые шары через некоторое время разделяются на маленькие гелевые шары
			    ▶ Усиления одного типа взаимоисключаемы
			'''
		SpilkeBallBonus_P1_2:
			'''
			Усиление шипастых шаров. Форма 1 | Опасность 2
			    ▶ Шипастые гелевые шары медленно преследуют игрока
			    ▶ Усиления одного типа взаимоисключаемы
			'''
		SpilkeBallBonus_P2_2:
			'''
			Усиление шипастых шаров. Форма 2 | Опасность 2
			    ▶ Шипастые гелевые шары периодически создают гелевые шипы
			    ▶ Усиления одного типа взаимоисключаемы
			'''
		StickyBonus_1:
			'''
			Усиление липкости | Опасность 1
			    ▶ Радиус создания липкой гелевой сети увеличен
			'''
	}

