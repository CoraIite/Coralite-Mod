IcicleSpirit: {
	DisplayName: Icicle Spirit
	BestiaryDescription: A spirit formed when the ice magic of Baby Ice Dragons spreads underground. Their ability to control ice magic is much weaker than that of Baby Ice Dragons.
}

MaragonBody.DisplayName: Maragon Body

MaragonHead: {
	DisplayName: Maragon Head
	BestiaryDescription: Creatures formed from gathered magic dust. It is speculated that they attack people because they mistake them for moving magic crystals.
}

