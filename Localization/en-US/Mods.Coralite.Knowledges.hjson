			'''
			Records information about Glistent Bars
			"A sparkling, shimmering metal bar"
			'''
	}

	ConstellationKnowledge: {
		Name: Constellation Scroll
		LockTip: Requires unleashing the ancient souls of light and dark
		Description: Power of the constellations
	}

	AlchemyKnowledge: {
		Name: Faded Legend
		LockTip: Stay tuned...
		Description: '''"Alchemy and Evolution"'''
	}

	MagikeToolWeapon1Knowledge: {
		Name: Magike Tools and Weapons
		LockTip: Unlocked after unlocking "Magike Fragment Vol.1"
		Description: Squander your excess magike!
	}

	SteelKnowledge: {
		Name: Steel Scroll
		LockTip: Requires unleashing the ancient souls of light and dark
		Description: '''"High-strength metal! Steel Ingots and B9 Alloy"'''
