	MagikeInterstitial1Knowledge: {
		Name: Magike Fragment Interlude - Crystalline Sky Island
		LockTip: Unlocked after right-clicking the Skarn Altar
		Description:
			'''
			Records information about the Skarn Altar
			Activate the altar and unlock the seal of the Crystalline Sky Island
			'''
	}

	NightmareKnowledge: {
		Name: Nightmare Fragment
		LockTip: Unlocked after defeating the Moon Lord
		Description:
			'''
			Sleep...
			Challenge the Nightmare Lord in your dreams
			'''
	}

	RedJadeKnowledge: {
		Name: Red Jade Fragment
		LockTip: Unlocked after obtaining "Hidden Red" or "Red Berry"
		Description:
			'''
			Records information about Red Jade and Rediancie
			What is the red energy that appears out of nowhere?
			'''
	}

	Slime1Knowledge: {
		Name: Slime Fragment
		LockTip:
			'''
			Slimes occasionally carry slime saplings
			Unlocked after obtaining a "Slime Sapling" and unlocking "Magike Fragment Vol.1"
			'''
		Description:
			'''
			Records the information of a supreme emperor
			From the Slime Kingdom
			'''
		LifeMaxBonus_1:
			'''
			Health Boost 1 | Danger Level 1
			    ▶ Slime Emperor health increased by 50%
			    ▶ Same type enhancements do not stack
			'''
		LifeMaxBonus_2:
			'''
			Health Boost 2 | Danger Level 2
			    ▶ Slime Emperor health increased by 75%
			    ▶ Same type enhancements do not stack
			'''
		LifeMaxBonus_3:
			'''
			Health Boost 3 | Danger Level 3
			    ▶ Slime Emperor health increased by 100%
			    ▶ Same type enhancements do not stack
			'''
		DefenceBonus_1:
			'''
			Defense Boost 1 | Danger Level 1
			    ▶ Slime Emperor defense increased by 8
			    ▶ Same type enhancements do not stack
			'''
		DefenceBonus_2:
			'''
			Defense Boost 2 | Danger Level 2
			    ▶ Slime Emperor defense increased by 15
			    ▶ Same type enhancements do not stack
			'''
		SpeedBonus1_1:
			'''
			Swift Action 1 | Danger Level 1
			    ▶ Slime Emperor jump and fall speed increased
			    ▶ Same type enhancements stack
			'''
		SpeedBonus2_1:
			'''
			Swift Action 2 | Danger Level 1
			    ▶ Slime Emperor crown form speed increased, elastic deformation speed increased
			    ▶ Same type enhancements stack
			'''
		SpeedBonus3_1:
			'''
			Swift Action 3 | Danger Level 1
			    ▶ Slime Emperor attack pattern changes, some attacks are faster
			    ▶ Same type enhancements stack
			'''
		WeaponLimit_4:
			'''
			Weapon Restriction | Danger Level 4
			    ▶ Can only use weapons below Bright Red rarity and damage ≤ 45
			    ▶ When this modifier is active, summons need to be re-summoned after entering battle
			'''
		ArmorLimit_4:
			'''
			Armor Restriction | Danger Level 4
			    ▶ Can only wear accessories and armor below Pink rarity with defense ≤ 9 per piece
			'''
		HitLimit_3:
			'''
			Hit Limit | Danger Level 3
			    ▶ Can only take up to 10 hits during the entire battle
			'''
		HitLimit_S_5:
			'''
			Hit Limit S | Danger Level 5
			    ▶ Can only take up to 1 hit during the entire battle
			'''
		FlippyBonus_1:
			'''
			Wing Enhancement 1 | Danger Level 1
			    ▶ Winged Slimes no longer lose health when generating gel balls, disappearing after 12 gel balls
			    ▶ Winged Slime health increased by 25%
			    ▶ Same type enhancements stack
			'''
		FlippyBonus_S_2:
			'''
			Wing Enhancement 2 | Danger Level 2
			    ▶ Winged Slimes move in a wider range, generate gel balls faster, and change velocity direction when dropping
			    ▶ Same type enhancements stack
			'''
		AvatarBonus_1:
			'''
			Minion Enhancement 1 | Danger Level 1
			    ▶ Slime minion health increased by 50%, inherits full health when splitting
			    ▶ Same type enhancements stack
			'''
		AvatarBonus_S_2:
			'''
			Minion Enhancement 2 | Danger Level 2
			    ▶ Slime minions split faster
			    ▶ Slime minions can split into 3, scattering in all directions
			    ▶ Same type enhancements stack
			'''
		CrownBonus_1:
			'''
			Crown Enhancement | Danger Level 1
			    ▶ Slime Emperor gains an additional 20 defense in crown form
			    ▶ Same type enhancements do not stack
			'''
		CrownBonus_S_2:
			'''
			Crown Enhancement S | Danger Level 2
			    ▶ Slime Emperor gains super armor in crown form (damage taken becomes 1)
			      and reflects some projectiles
			    ▶ Same type enhancements do not stack
			'''
		ElasticBonus_1:
			'''
			Elastic Enhancement | Danger Level 1
			    ▶ Bouncy slime balls no longer break upon hitting attacks
			'''
		GelBallBonus_P1_2:
			'''
			Gel Ball Enhancement Form 1 | Danger Level 2
			    ▶ Gel balls do not lose speed on bounce and deflect toward the player, bounce count increased
			    ▶ Mutually exclusive with same type enhancements
			'''
		GelBallBonus_P2_2:
			'''
			Gel Ball Enhancement Form 2 | Danger Level 2
			    ▶ Gel balls split into small gel balls after a period of time
			    ▶ Mutually exclusive with same type enhancements
			'''
		SpilkeBallBonus_P1_2:
			'''
			Spike Ball Enhancement Form 1 | Danger Level 2
			    ▶ Gel spike balls slowly track the player after generation
			    ▶ Mutually exclusive with same type enhancements
			'''
		SpilkeBallBonus_P2_2:
			'''
			Spike Ball Enhancement Form 2 | Danger Level 2
			    ▶ Gel spike balls generate gel spikes at intervals
			    ▶ Mutually exclusive with same type enhancements
			'''
		StickyBonus_1:
			'''
			Sticky Enhancement | Danger Level 1
			    ▶ Sticky gel web generation range expanded
			'''
	}

	SwordKnowledge: {
		Name: The Infinite Sword
		LockTip: If you see this line, it means there's a bug, please report to the mod author
		Description: The ultimate sword forged at the pinnacle of the journey
	}

	Thunder1Knowledge: {
		Name: Thunder Dragon Fragment
		LockTip: Unlocked after defeating "The Twins", "Skeletron Prime", and "The Destroyer" in Hardmode
		Description:
			'''
			Records information about the thunder dragon
			A two-legged wyvern dwelling in the clouds that commands lightning
			'''
	}

	GlistentKnowledge: {
		Name: Glistent Scroll
		LockTip: Unlocked after obtaining [i:Coralite/LeafStone] Leaf Stone or [i:Coralite/GlistentBar] Glistent Bar
